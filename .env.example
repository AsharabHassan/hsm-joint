# ─── GoHighLevel Webhooks ────────────────────────────────────────────────────
#
# Each page resolves its own webhook URL.
# Naming convention: GHL_WEBHOOK_URL_<PAGE_SLUG_UPPERCASED_WITH_UNDERSCORES>
#
# If a page-specific key is missing, it falls back to GHL_WEBHOOK_URL.
# ─────────────────────────────────────────────────────────────────────────────

# Global fallback (used if no page-specific key is set)
GHL_WEBHOOK_URL=

# Treatment pages
GHL_WEBHOOK_URL_PRP=
GHL_WEBHOOK_URL_EXOSOMES=
GHL_WEBHOOK_URL_STEM_CELLS=
GHL_WEBHOOK_URL_CORTISONE_INJECTIONS=
GHL_WEBHOOK_URL_JOINT_PAIN=
GHL_WEBHOOK_URL_PAIN_MANAGEMENT_LONDON=

# Body area pages (dynamic /[bodyArea] routes)
GHL_WEBHOOK_URL_KNEE_PAIN=
GHL_WEBHOOK_URL_HIP_PAIN=
GHL_WEBHOOK_URL_SHOULDER_PAIN=
GHL_WEBHOOK_URL_BACK_PAIN=
GHL_WEBHOOK_URL_ELBOW_PAIN=
GHL_WEBHOOK_URL_HAND_WRIST_FOOT_ANKLE=

